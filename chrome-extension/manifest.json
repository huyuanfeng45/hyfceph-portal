{
  "manifest_version": 3,
  "name": "HYFCeph Bridge",
  "version": "1.0.3",
  "description": "Sync the owner's active ceph browser session to HYFCeph and auto re-login after timed logout.",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://pd.aiyayi.com/*",
    "https://hyfceph.52ortho.com/*",
    "https://api.day.app/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "HYFCeph Bridge",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pd.aiyayi.com/latera/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
